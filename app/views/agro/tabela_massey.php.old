<?php
/** Variáveis esperadas do controller:
 * @var string|null $erro
 * @var array $rows
 * @var array $soSistema
 * @var array $soPlanilha
 * @var string $uiOver
 * @var string $uiIndice
 * @var string $marcaNome
 * @var string|null $base  // defina no controller: $base = base_url('agro/tabela-massey')
 */
$flash = $_SESSION['massey_flash'] ?? null;
unset($_SESSION['massey_flash']);

$reqBase = htmlspecialchars(strtok($_SERVER['REQUEST_URI'] ?? '', '?'));
$base = isset($base) && is_string($base) && $base !== '' ? $base : ($reqBase ?: '#');

// Contadores
$totalRows      = is_array($rows) ? count($rows) : 0;
$totalSoSistema = is_array($soSistema) ? count($soSistema) : 0;
$totalSoPlan    = is_array($soPlanilha) ? count($soPlanilha) : 0;
?>

<section class="content pt-3">
  <div class="container-fluid">

    <div class="card">
      <div class="card-header d-flex align-items-center justify-content-between">
        <h3 class="card-title mb-0">Agro — Tabela Massey Ferguson</h3>
        <span class="text-muted small">
          Marca: <strong><?= htmlspecialchars($marcaNome ?? 'Massey Ferguson') ?></strong>
        </span>
      </div>

      <!-- CARD BODY: Mensagens de sistema -->
      <div class="card-body">

        <?php if ($flash): ?>
          <div class="alert alert-success" role="alert">
            <pre class="mb-0" style="white-space:pre-wrap;"><?= htmlspecialchars($flash) ?></pre>
          </div>
        <?php endif; ?>

        <?php if ($erro): ?>
          <div class="alert alert-danger" role="alert">
            <pre class="mb-0" style="white-space:pre-wrap;"><?= htmlspecialchars($erro) ?></pre>
          </div>
        <?php endif; ?>



        <form method="post" enctype="multipart/form-data" class="mb-3">
			
		<div class="form-row">
          <div class="form-group col-md-8">
			<label>Clique no botão abaixo e selecione o arquivo com a lista de preços</label>
            <input type="file" name="arquivo" accept=".lp%," class="form-control-file" required>
			<small class="form-text text-muted">
                O arquivo anexo deve ser o enviado pelo fabricante no forma "lp%", sem manipulações. 
            </small>
          </div>
		</div>
		<div class="form-row">
		
          <div class="col-12 col-md-6">
            <label class="form-label">Overprice</label>
            <input type="text" name="overprice" value="<?= htmlspecialchars($uiOver ?? '15%') ?>" class="form-control" placeholder="15% ou 0,15">
            <div class="form-text">Percentual a ser adicionado ao valor sugerído pelo fabricante "Preço Publico"</div>
          </div>

          <div class="col-12 col-md-6">
            <label class="form-label">Índice para Custo</label>
            <input type="text" name="indice_custo" value="<?= htmlspecialchars($uiIndice ?? '70%') ?>" class="form-control" placeholder="70% ou 0,70">
            <div class="form-text">Percentual a do valor sugerído pelo fabricante para formar o "Preço Garantia" e "Preço Reposição"</div>
          </div>
		</div>
		
		<!-- Quebra linha -->
		
		<div class="form-row">
			<div class="form-group col-md-8">
			  <!-- Marca ID oculto (fixo) -->
			  <input type="hidden" name="marca_id" value="96">
			
			  
				<button type="submit" class="btn btn-primary">
				  <i class="fas fa-cog me-1"></i> Processar
				</button>
				<a class="btn btn-outline-secondary" href="<?= $base ?>?export=1">
				  <i class="fas fa-file-export me-1"></i> Exportar CSV
				</a>
			 </div>
		 </div>

        </form>
		
		
		<ul class="nav nav-tabs" id="mfTabs" role="tablist">
