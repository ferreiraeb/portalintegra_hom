                        <td><?= htmlspecialchars($r['ProdutoDescricao'] ?? '') ?></td>
                        <td><?= htmlspecialchars(trim(($r['NCMIdentificador'] ?? '').' '.($r['NCMCodigo'] ?? ''))) ?></td>
