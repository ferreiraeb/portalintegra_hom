          <div class="tab-pane fade" id="pane-sistema" role="tabpanel" aria-labelledby="tab-sistema">
            <div class="text-muted mb-2">
              Os itens desta lista não foram localizados na planilha anexa, porém estão presentes no DealerNet.
              Total de linhas: <strong><?= number_format($totalSoSistema,0,',','.') ?></strong>
            </div>

            <?php if ($totalSoSistema === 0): ?>
              <div class="text-muted">Nenhum registro.</div>
            <?php else: ?>
